# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/market_dashboard"

# ─── Redis (for caching) ──────────────────────────────────────────────────────
# Option A: local Redis
REDIS_URL="redis://localhost:6379"
# Option B: Upstash (serverless, works on Vercel)
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-token"

# ─── External Price APIs ──────────────────────────────────────────────────────
# GoldAPI.io (free tier: 50 req/month → upgrade for production)
GOLDAPI_KEY="your-goldapi-key"

# ExchangeRate-API (free tier: 1500 req/month)
EXCHANGERATE_API_KEY="your-exchangerate-key"

# CoinGecko (free tier, no key needed for public endpoints)
# COINGECKO_API_KEY="optional-pro-key"

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string-in-production"
NEXTAUTH_SECRET="change-me-too"
NEXTAUTH_URL="http://localhost:3000"

# ─── Email Alerts (optional) ──────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"

# ─── App Settings ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="سوق | Souq"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# Cache TTL in seconds (default 5 minutes for prices)
CACHE_TTL_PRICES=300
# How often the cron job runs (default: every 5 minutes)
CRON_INTERVAL_MINUTES=5
